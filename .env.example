# ========================================
# Threads Studio - 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# ========================================

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/threads_studio

# Authentication - 必ず本番用に変更してください
JWT_SECRET=your-secure-random-secret-key-here

# App
VITE_APP_ID=threads-studio
VITE_APP_URL=https://your-domain.com
NODE_ENV=development

# Threads API (Meta Developer Console で取得)
THREADS_APP_ID=your-threads-app-id
THREADS_APP_SECRET=your-threads-app-secret
THREADS_REDIRECT_BASE_URL=http://localhost:3000

# AI API (Google Gemini)
BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
BUILT_IN_FORGE_API_KEY=your-gemini-api-key

# Stripe (決済)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# UniVaPay (日本向け決済) - オプション
UNIVAPAY_STORE_ID=
UNIVAPAY_JWT_TOKEN=
UNIVAPAY_WEBHOOK_SECRET=

# Resend (メール送信)
RESEND_API_KEY=re_...
RESEND_FROM_DOMAIN=your-domain.com

# OAuth
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Sentry (エラー監視) - オプション
SENTRY_DSN=

# Token encryption key (32 bytes hex) - openssl rand -hex 32 で生成
TOKEN_ENCRYPTION_KEY=
